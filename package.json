{
  "name": "javascript-salesforce-connector",
  "version": "1.0.3",
  "description": "Salesforce ORM-like module with ActiveRecord-style interface",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sfc": "./dist/cli/sfc.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "salesforce",
    "orm",
    "activerecord",
    "fastify",
    "typescript",
    "rest-api",
    "soql",
    "query-builder"
  ],
  "author": "Berat Yuseinov <berat.yuseinov@abv.bg>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Berat-Dzhevdetov/salesforce-connector.git"
  },
  "bugs": {
    "url": "https://github.com/Berat-Dzhevdetov/salesforce-connector/issues"
  },
  "homepage": "https://github.com/Berat-Dzhevdetov/salesforce-connector#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "commander": "^14.0.3",
    "jsonwebtoken": "^9.0.3",
    "ts-morph": "^27.0.2"
  }
}
